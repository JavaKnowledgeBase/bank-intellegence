# ── CSIP Backend — Local Development Environment ──────────────────────────────
# Copy to .env and fill in your values.
# In production, all secrets come from HashiCorp Vault (VAULT_BYPASS=false).

# Core
ENVIRONMENT=development
CSIP_PORT=8092
LOG_LEVEL=INFO

# Auth (set AUTH_BYPASS=false in prod and configure JWT_SECRET)
AUTH_BYPASS=true
JWT_SECRET=dev-secret-change-in-prod

# Database (must match CIBAP docker-compose)
DATABASE_URL=postgresql+asyncpg://cibap_user:changeme@localhost:5432/cibap

# Redis (must match CIBAP docker-compose)
REDIS_URL=redis://localhost:6379

# Kafka (must match CIBAP docker-compose)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Anthropic Claude API key (REQUIRED for RCA and Code Fix)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub (optional — enables PR creation in Code Fix pipeline)
GITHUB_TOKEN=ghp_...

# Vector store — chromadb (local) or pinecone (prod)
VECTOR_STORE_BACKEND=chromadb
CHROMADB_PATH=./data/chromadb
# PINECONE_API_KEY=...
# PINECONE_ENVIRONMENT=us-east-1

# Vault (set VAULT_BYPASS=false and configure in prod)
VAULT_BYPASS=true
VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=...

# Observability (optional)
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317

# PagerDuty (optional)
# PAGERDUTY_INTEGRATION_KEY=...

# AWS S3 audit archival (optional)
S3_ENABLED=false
S3_AUDIT_BUCKET=csip-audit-logs
AWS_REGION=us-east-1
